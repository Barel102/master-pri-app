# --- Local development (SQLite file) ---
DATABASE_URL="file:./dev.db"

# --- Production on Vercel (Turso — free tier) ---
# Create a DB at https://turso.tech then run:
#   turso db show YOUR_DB_NAME --url
#   turso db tokens create YOUR_DB_NAME
# DATABASE_URL="libsql://your-database-name-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Admin panel password (required in production)
ADMIN_PASSWORD="change-me-before-deploy"
